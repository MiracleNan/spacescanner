<Window x:Class="MftScanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spacescanner Plus Max Ultra Pro Hyper X Elite Supreme Edition" Height="600" Width="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#F0F0F0" Padding="10" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="选择驱动器:" VerticalAlignment="Center" Margin="0,0,10,0"/>

                <ComboBox x:Name="DriveSelector" Width="120" VerticalContentAlignment="Center"/>

                <Button x:Name="BtnAnalyze" Content="开始分析" Width="100" Margin="10,0,0,0" 
                        Click="BtnAnalyze_Click" Background="#007ACC" Foreground="White"/>

                <TextBlock x:Name="StatusText" Text="准备就绪" VerticalAlignment="Center" Margin="20,0,0,0" Foreground="Gray"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" ClipToBounds="True">
            <Canvas x:Name="TreemapCanvas" Background="White" SizeChanged="TreemapCanvas_SizeChanged"/>
        </Border>

        <Popup x:Name="InfoPopup" Placement="Mouse" IsOpen="False" AllowsTransparency="True">
            <Border Background="#CC000000" CornerRadius="5" Padding="10">
                <TextBlock x:Name="PopupText" Foreground="White"/>
            </Border>
        </Popup>
    </Grid>
</Window>